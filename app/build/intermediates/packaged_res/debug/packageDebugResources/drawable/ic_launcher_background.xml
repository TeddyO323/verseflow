<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#050814" />
        </shape>
    </item>

    <item
        android:width="76dp"
        android:height="76dp"
        android:gravity="bottom|start"
        android:left="4dp"
        android:bottom="-4dp">
        <shape android:shape="oval">
            <solid android:color="#300000FF" />
        </shape>
    </item>

    <item
        android:width="42dp"
        android:height="42dp"
        android:gravity="top|end"
        android:top="8dp"
        android:right="8dp">
        <shape android:shape="oval">
            <solid android:color="#1766F2FF" />
        </shape>
    </item>

    <item
        android:width="30dp"
        android:height="30dp"
        android:gravity="bottom|end"
        android:right="6dp"
        android:bottom="10dp">
        <shape android:shape="oval">
            <solid android:color="#1A203BFF" />
        </shape>
    </item>
</layer-list>
